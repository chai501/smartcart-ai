# Copy this file to .env and fill in your actual values

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smart-ecommerce?retryWrites=true&w=majority

# JWT Secret — use a long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Port for the backend server
PORT=5000

# URL where the Python ML service is running (use Render service URL in production)
ML_SERVICE_URL=http://localhost:8000

# Amazon Product Advertising API credentials
# Sign up at: https://affiliate-program.amazon.com/assoc_credentials/home
# NOTE: If you don't have access yet, the app will fall back to Open Product Data (upcitemdb)
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your_associate_tag
AMAZON_REGION=us-east-1

# Fallback: RapidAPI key for Amazon product search (free tier available)
# Sign up at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
RAPIDAPI_KEY=your_rapidapi_key

# Frontend URL for CORS (set to your Vercel/Netlify URL in production)
FRONTEND_URL=http://localhost:3000
